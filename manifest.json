{
  "manifest_version": 3,
  "name": "Secret Sanitizer – Paste Safely into AI Chats",
  "version": "2.2.5",
  "description": "Accidentally paste API keys into ChatGPT or Claude? Secret Sanitizer masks them instantly — 100% local, zero servers, open source.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "scripting",
    "alarms",
    "notifications",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://grok.com/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [{
    "resources": ["icons/icon-128.png"],
    "matches": ["*://chatgpt.com/*", "*://claude.ai/*", "*://gemini.google.com/*", "*://grok.com/*"]
  }]
}